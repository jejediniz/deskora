NODE_ENV=development

# JWT — gere SEMPRE um valor aleatório de pelo menos 32 caracteres.
# Em produção, valores fracos/curtos fazem o app abortar no boot.
# Geração recomendada: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Cookie de sessão. Em produção é forçado o prefixo __Host- automaticamente.
AUTH_COOKIE_NAME=operadesk_session
AUTH_COOKIE_MAX_AGE=28800

# Custo do bcrypt. Mínimo aceito em produção: 12.
BCRYPT_ROUNDS=12

# Logging: debug | info | warn | error. Default: info em prod, debug em dev.
LOG_LEVEL=debug

# PostgreSQL
# O docker-compose mapeia o container 5432 para 5433 do host.
# Use 5433 aqui se você roda o Next fora do Docker (ex.: npm run dev:full).
DB_HOST=localhost
DB_PORT=5433
DB_USER=operadesk
DB_PASSWORD=operadesk
DB_NAME=operadesk
DB_POOL_MAX=10

# Usada pelo node-pg-migrate (scripts db:migrate*)
DATABASE_URL=postgres://operadesk:operadesk@localhost:5433/operadesk
