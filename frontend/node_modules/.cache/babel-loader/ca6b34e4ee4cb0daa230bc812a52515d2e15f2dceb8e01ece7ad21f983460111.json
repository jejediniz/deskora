{"ast":null,"code":"import{useEffect,useState}from\"react\";export function useAnimatedNumber(valor){let duracao=arguments.length>1&&arguments[1]!==undefined?arguments[1]:500;const[animado,setAnimado]=useState(0);useEffect(()=>{let inicio=0;const incremento=Math.max(1,Math.ceil(valor/(duracao/16)));let frameId=null;function animar(){inicio+=incremento;if(inicio>=valor){setAnimado(valor);return;}setAnimado(inicio);frameId=window.requestAnimationFrame(animar);}animar();return()=>{if(frameId){window.cancelAnimationFrame(frameId);}};},[valor,duracao]);return animado;}","map":{"version":3,"names":["useEffect","useState","useAnimatedNumber","valor","duracao","arguments","length","undefined","animado","setAnimado","inicio","incremento","Math","max","ceil","frameId","animar","window","requestAnimationFrame","cancelAnimationFrame"],"sources":["/home/diniz_jessica/development/deskora/frontend/src/hooks/useAnimatedNumber.js"],"sourcesContent":["import { useEffect, useState } from \"react\";\n\nexport function useAnimatedNumber(valor, duracao = 500) {\n  const [animado, setAnimado] = useState(0);\n\n  useEffect(() => {\n    let inicio = 0;\n    const incremento = Math.max(1, Math.ceil(valor / (duracao / 16)));\n    let frameId = null;\n\n    function animar() {\n      inicio += incremento;\n\n      if (inicio >= valor) {\n        setAnimado(valor);\n        return;\n      }\n\n      setAnimado(inicio);\n      frameId = window.requestAnimationFrame(animar);\n    }\n\n    animar();\n\n    return () => {\n      if (frameId) {\n        window.cancelAnimationFrame(frameId);\n      }\n    };\n  }, [valor, duracao]);\n\n  return animado;\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,MAAO,SAAS,CAAAC,iBAAiBA,CAACC,KAAK,CAAiB,IAAf,CAAAC,OAAO,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CACpD,KAAM,CAACG,OAAO,CAAEC,UAAU,CAAC,CAAGR,QAAQ,CAAC,CAAC,CAAC,CAEzCD,SAAS,CAAC,IAAM,CACd,GAAI,CAAAU,MAAM,CAAG,CAAC,CACd,KAAM,CAAAC,UAAU,CAAGC,IAAI,CAACC,GAAG,CAAC,CAAC